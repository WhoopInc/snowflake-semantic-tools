<!DOCTYPE html>
<html lang="en" data-theme="auto">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SST Documentation{% endblock %}</title>
    <style>{{ pico_css }}</style>
    <style>{{ app_css }}</style>
    {% block head_extra %}{% endblock %}
</head>
<body>
    <nav class="sst-nav">
        <a href="index.html" class="sst-nav-brand">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            SST Docs
        </a>
        <div class="sst-nav-links">
            <a href="index.html" class="{% block nav_catalog_class %}{% endblock %}">Catalog</a>
            <a href="lineage.html" class="{% block nav_lineage_class %}{% endblock %}">Lineage</a>
            {% block nav_extra %}{% endblock %}
        </div>
    </nav>
    {% block content %}{% endblock %}
    <footer class="sst-footer">
        Generated by <a href="https://github.com/WhoopInc/snowflake-semantic-tools">SST</a> v{{ sst_version }} on {{ generated_at }}
    </footer>
    {% block scripts %}{% endblock %}
</body>
</html>
